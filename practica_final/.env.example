# PostgreSQL control
POSTGRES_USER=dcc_admin
POSTGRES_PASSWORD=dcc_secret_change_me
POSTGRES_DB=dcc_control
# En Windows, si tienes PostgreSQL instalado en 5432, usa 5433 para el contenedor Docker
POSTGRES_PORT=5433

# API / JWT
JWT_KEY=dcc-jwt-dev-key-change-in-production-min-32-chars!!
DCC_ADMIN_USER=admin
DCC_ADMIN_PASSWORD=Admin123!

# --- Módulo 5: replicación de backups a Amazon S3 (AWS) ---
# Crea el bucket en la misma región que AWS_DEFAULT_REGION.
# IAM mínimo: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket sobre el bucket/prefix.
S3_BUCKET=mi-empresa-dcc-backups
S3_PREFIX=dcc-control/
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Dejar vacío para AWS real. Solo usar con MinIO local:
# S3_ENDPOINT_URL=http://minio:9000

RETENTION_DAYS=14
FULL_BOOTSTRAP_ON_STARTUP=1

# --- Modulo 9: alertas por correo (Gmail: usar contraseña de aplicacion) ---
Alerts__SmtpHost=smtp.gmail.com
Alerts__SmtpPort=587
Alerts__SmtpSsl=true
Alerts__SmtpUser=tu_cuenta@gmail.com
Alerts__SmtpPassword=
Alerts__EmailFrom=tu_cuenta@gmail.com
Alerts__EmailTo=destino@ejemplo.com
